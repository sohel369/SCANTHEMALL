{
  "name": "gtsa-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "admin-panel",
    "advertiser-panel"
  ],
  "scripts": {
    "build:admin": "npm run build -w admin-panel",
