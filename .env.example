# Database Configuration (Railway provides DATABASE_URL automatically if you add a PG service)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Authentication
JWT_SECRET=your_jwt_secret_here

# Paths (Keep these defaults for Railway)
UPLOADS_DIR=src/uploads

# Application URLs (Optional, used for CORS)
FRONTEND_URL=https://your-app-domain.railway.app
ADMIN_PANEL_URL=https://your-app-domain.railway.app/admin
ADVERTISER_PANEL_URL=https://your-app-domain.railway.app/advertiser

# Node Environment
NODE_ENV=production
PORT=4000
